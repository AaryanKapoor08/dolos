{
  "realm": "dolos",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "ANALYST", "description": "Investigate cases, add evidence, assign, close." },
      { "name": "SENIOR_ANALYST", "description": "ANALYST plus escalate cases and file SAR/STR reports." },
      { "name": "ADMIN", "description": "Administer the platform." }
    ]
  },
  "clients": [
    {
      "clientId": "dolos-gateway",
      "name": "Dolos Gateway / UI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "dolos-gateway-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    },
    {
      "clientId": "dolos-copilot",
      "name": "Dolos AI Copilot (service)",
      "description": "Service client the ai-copilot-service uses to call the secured case-service (Phase 4D).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "dolos-copilot-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "dolos-console",
      "name": "Dolos Investigator Console (SPA)",
      "description": "Public PKCE client for the React console (Phase 5E): browser OIDC login (Auth Code + PKCE).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    }
  ],
  "users": [
    {
      "username": "analyst",
      "enabled": true,
      "emailVerified": true,
      "email": "analyst@dolos.local",
      "firstName": "Ana",
      "lastName": "Lyst",
      "requiredActions": [],
      "credentials": [{ "type": "password", "value": "analyst", "temporary": false }],
      "realmRoles": ["ANALYST"]
    },
    {
      "username": "senior",
      "enabled": true,
      "emailVerified": true,
      "email": "senior@dolos.local",
      "firstName": "Senna",
      "lastName": "Yore",
      "requiredActions": [],
      "credentials": [{ "type": "password", "value": "senior", "temporary": false }],
      "realmRoles": ["ANALYST", "SENIOR_ANALYST"]
    },
    {
      "username": "admin-user",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@dolos.local",
      "firstName": "Addy",
      "lastName": "Min",
      "requiredActions": [],
      "credentials": [{ "type": "password", "value": "admin-user", "temporary": false }],
      "realmRoles": ["ANALYST", "SENIOR_ANALYST", "ADMIN"]
    },
    {
      "username": "service-account-dolos-copilot",
      "enabled": true,
      "serviceAccountClientId": "dolos-copilot",
      "realmRoles": ["ANALYST", "SENIOR_ANALYST"]
    }
  ]
}

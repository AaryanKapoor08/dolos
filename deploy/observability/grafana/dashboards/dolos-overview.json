{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["dolos", "phase-6a"],
  "title": "Dolos platform overview",
  "uid": "dolos-overview",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Metrics (Prometheus)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Services up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
      "targets": [
        { "refId": "A", "expr": "count(up{job=\"dolos-services\"} == 1)", "legendFormat": "up" }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by service (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "refId": "A", "expr": "sum by (service) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process CPU usage by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage{job=\"dolos-services\"}", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka listener throughput (records/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "expr": "sum by (service) (rate(spring_kafka_listener_seconds_count[1m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "row",
      "title": "Traces (Tempo)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "type": "table",
      "title": "Recent traces (TraceQL {})",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "targets": [
        { "refId": "A", "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{}", "limit": 20, "tableType": "traces" }
      ]
    },
    {
      "type": "row",
      "title": "Logs (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },
    {
      "type": "logs",
      "title": "Service logs (traceId links to Tempo)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{service=~\".+\"}", "queryType": "range" }
      ]
    }
  ]
}

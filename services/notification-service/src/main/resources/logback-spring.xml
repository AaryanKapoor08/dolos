<?xml version="1.0" encoding="UTF-8"?>
<!--
  Structured (JSON) logging — observability baseline (matches every other Dolos service).
  LogstashEncoder emits one JSON object per log line and includes any SLF4J MDC entries; the
  static `service` field tags the source so logs are filterable once many services ship logs.
-->
<configuration>
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"notification-service"}</customFields>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON"/>
    </root>
</configuration>

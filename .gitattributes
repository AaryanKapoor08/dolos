# Normalize line endings: store text as LF in the repo.
* text=auto eol=lf

# Windows batch scripts must stay CRLF.
*.bat  text eol=crlf
*.cmd  text eol=crlf

# The Gradle wrapper script must be LF (it runs on Linux/CI).
gradlew text eol=lf

# Binary assets — never normalize.
*.jar  binary
*.png  binary
*.jpg  binary
*.pdf  binary
*.ico  binary
